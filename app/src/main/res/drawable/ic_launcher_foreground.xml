<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ══════════════════════════════════════════════════════════
         LEAF BODY — gradient from bright green (top) to teal-blue (bottom)
         ══════════════════════════════════════════════════════════ -->
    <path android:pathData="
        M54,22
        C57,25 62,32 64,40
        C66,48 66,54 64,60
        C62,66 58,72 54,78
        C50,72 46,66 44,60
        C42,54 42,48 44,40
        C46,32 51,25 54,22Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="22"
                android:endX="54"
                android:endY="78"
                android:type="linear">
                <item android:color="#FF43A047" android:offset="0.0" />
                <item android:color="#FF2E7D32" android:offset="0.45" />
                <item android:color="#FF00897B" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ══════════════════════════════════════════════════════════
         CENTRAL VEIN — midrib from leaf tip to base
         ══════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,26 L54,76"
        android:strokeWidth="1.8"
        android:strokeColor="#1B5E20"
        android:strokeLineCap="round" />

    <!-- ══════════════════════════════════════════════════════════
         HEALTHCARE CROSS — integrated into upper-center of leaf
         Vertical bar
         ══════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#E0F7FA"
        android:pathData="
            M52.2,36
            L55.8,36
            L55.8,48
            L52.2,48Z" />

    <!-- HEALTHCARE CROSS — Horizontal bar -->
    <path
        android:fillColor="#E0F7FA"
        android:pathData="
            M48,39.6
            L60,39.6
            L60,44.4
            L48,44.4Z" />

    <!-- ══════════════════════════════════════════════════════════
         STEM — thin branch extending downward from leaf base
         ══════════════════════════════════════════════════════════ -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,77 C54,82 54,86 54,92"
        android:strokeWidth="2.2"
        android:strokeColor="#2E7D32"
        android:strokeLineCap="round" />

</vector>
